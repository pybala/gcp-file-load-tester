# =============================================================================
# .gitignore — BigQuery Data Validation Framework
# =============================================================================

# -----------------------------------------------------------------------------
# Python virtual environment
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Python bytecode and cache
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.pyw

# -----------------------------------------------------------------------------
# Python packaging & distribution
# -----------------------------------------------------------------------------
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# GCP credentials and secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
*.json
!requirements*.json   # keep any json that is not a key

# Note: .env.example is intentionally NOT ignored — it is the safe template.
# Note: tests/*/validation_config.yaml files are NOT ignored — they are config only,
#       no secrets. All secrets must live in .env only.

# -----------------------------------------------------------------------------
# Test result output files
# -----------------------------------------------------------------------------
tests/**/results.json
results/
*.results.json
output/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.iml
*.suo
*.user
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Coverage, testing, profiling
# -----------------------------------------------------------------------------
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# -----------------------------------------------------------------------------
# Type checker / linter caches
# -----------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.flake8
.pytype/

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Temporary and scratch files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig